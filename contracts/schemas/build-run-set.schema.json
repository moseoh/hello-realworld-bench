{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/build-run-set.schema.json",
  "title": "Build run set",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_set_id", "run_id", "manifest_digest", "cohort_fingerprint", "status", "trials"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_set_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "manifest_digest": { "type": "string", "pattern": "^[0-9a-f]{64}(?![\\s\\S])" },
    "cohort_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}(?![\\s\\S])" },
    "status": { "const": "complete" },
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trial_id", "index", "status"],
        "properties": {
          "trial_id": { "type": "string", "minLength": 1 },
          "index": { "type": "integer", "minimum": 1 },
          "status": { "enum": ["valid", "invalid", "failed"] }
        }
      }
    }
  }
}
