{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/scenario.schema.json",
  "title": "Benchmark scenario contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "kind",
    "question",
    "measures",
    "does_not_measure",
    "dependencies",
    "variants",
    "default_profiles",
    "target",
    "services",
    "load",
    "metrics"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["smoke", "lifecycle", "service"]
    },
    "question": { "type": "string", "minLength": 1 },
    "measures": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "does_not_measure": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "default_profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_profile",
        "measurement_protocol",
        "load_profile"
      ],
      "properties": {
        "environment_profile": { "type": "string", "minLength": 1 },
        "measurement_protocol": { "type": "string", "minLength": 1 },
        "load_profile": { "type": "string", "minLength": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url", "endpoint"],
      "properties": {
        "base_url": { "type": "string", "minLength": 1 },
        "startup_path": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 }
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postgres", "redis", "kafka", "mock_upstream"],
      "properties": {
        "postgres": { "type": "boolean" },
        "redis": { "type": "boolean" },
        "kafka": { "type": "boolean" },
        "mock_upstream": { "type": "boolean" }
      }
    },
    "load": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "tool": { "type": "string", "minLength": 1 },
        "script": { "type": "string", "minLength": 1 },
        "warmup_duration": { "type": "string", "minLength": 1 },
        "test_duration": { "type": "string", "minLength": 1 },
        "vus": { "type": "integer", "minimum": 0 },
        "docker_stats_interval_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "required": [
              "tool",
              "script",
              "warmup_duration",
              "test_duration",
              "vus"
            ]
          }
        }
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collect"],
      "properties": {
        "collect": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "startup": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "iterations": { "type": "integer", "minimum": 1 },
        "poll_interval_seconds": {
          "type": "number",
          "minimum": 0
        },
        "timeout_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
