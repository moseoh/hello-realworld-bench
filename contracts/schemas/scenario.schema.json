{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/scenario.schema.json",
  "title": "Benchmark scenario contract",
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "kind",
    "question",
    "measures",
    "does_not_measure",
    "dependencies",
    "variants",
    "default_profiles",
    "target",
    "services",
    "load",
    "metrics"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/slug" },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["smoke", "lifecycle", "service"]
    },
    "question": { "type": "string", "minLength": 1 },
    "measures": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "does_not_measure": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "$ref": "#/$defs/slug" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "default_profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_profile",
        "measurement_protocol",
        "load_profile"
      ],
      "properties": {
        "environment_profile": { "$ref": "#/$defs/slug" },
        "measurement_protocol": { "$ref": "#/$defs/slug" },
        "load_profile": { "$ref": "#/$defs/slug" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url", "endpoint"],
      "properties": {
        "base_url": { "type": "string", "minLength": 1 },
        "startup_path": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 }
      }
    },
    "services": {
      "type": "object",
      "additionalProperties": false,
      "required": ["postgres", "redis", "kafka", "mock_upstream"],
      "properties": {
        "postgres": { "type": "boolean" },
        "redis": { "type": "boolean" },
        "kafka": { "type": "boolean" },
        "mock_upstream": { "type": "boolean" }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "table", "row_count", "immutable", "fingerprint"],
      "properties": {
        "asset": { "type": "string", "minLength": 1 },
        "table": { "type": "string", "minLength": 1 },
        "row_count": { "type": "integer", "minimum": 1 },
        "immutable": { "type": "boolean" },
        "fingerprint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id_sum",
            "price_cents_sum",
            "rating_basis_points_sum",
            "active_count"
          ],
          "properties": {
            "id_sum": { "type": "integer", "minimum": 0 },
            "price_cents_sum": { "type": "integer", "minimum": 0 },
            "rating_basis_points_sum": { "type": "integer", "minimum": 0 },
            "active_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "query_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "categories",
        "price_windows",
        "page_sizes",
        "first_page_weight",
        "continuation_page_weight",
        "sort",
        "index",
        "min_selected_rows",
        "max_selected_rows",
        "max_response_bytes",
        "cache_temperature"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "price_windows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["min_price_cents", "max_price_cents"],
            "properties": {
              "min_price_cents": { "type": "integer", "minimum": 0 },
              "max_price_cents": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "page_sizes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1 }
        },
        "first_page_weight": { "type": "integer", "minimum": 1 },
        "continuation_page_weight": { "type": "integer", "minimum": 1 },
        "sort": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "index": { "type": "string", "minLength": 1 },
        "min_selected_rows": { "type": "integer", "minimum": 0 },
        "max_selected_rows": { "type": "integer", "minimum": 0 },
        "max_response_bytes": { "type": "integer", "minimum": 1 },
        "cache_temperature": { "type": "string", "enum": ["cold", "warm"] }
      }
    },
    "load": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "tool": { "type": "string", "minLength": 1 },
        "script": { "type": "string", "minLength": 1 },
        "warmup_duration": { "type": "string", "minLength": 1 },
        "test_duration": { "type": "string", "minLength": 1 },
        "vus": { "type": "integer", "minimum": 0 },
        "arrival_rate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["base_per_second", "pre_allocated_vus", "max_vus"],
          "properties": {
            "base_per_second": { "type": "integer", "minimum": 1 },
            "pre_allocated_vus": { "type": "integer", "minimum": 1 },
            "max_vus": { "type": "integer", "minimum": 1 },
            "calibrated": { "type": "boolean" }
          }
        },
        "docker_stats_interval_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "required": [
              "tool",
              "script",
              "warmup_duration",
              "test_duration",
              "vus"
            ]
          }
        }
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collect"],
      "properties": {
        "collect": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "startup": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "iterations": { "type": "integer", "minimum": 1 },
        "poll_interval_seconds": {
          "type": "number",
          "minimum": 0
        },
        "timeout_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
