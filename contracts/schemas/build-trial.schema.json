{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/build-trial.schema.json",
  "title": "Build trial evidence",
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}(?![\\s\\S])"
    },
    "duration": { "type": "number", "minimum": 0 }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "trial_id",
    "manifest_digest",
    "cohort_fingerprint",
    "status",
    "started_at",
    "finished_at",
    "metrics"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "trial_id": { "type": "string", "minLength": 1 },
    "manifest_digest": { "$ref": "#/$defs/digest" },
    "cohort_fingerprint": { "$ref": "#/$defs/digest" },
    "status": { "enum": ["valid", "invalid", "failed"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gradle_clean_build_ms",
        "gradle_incremental_rebuild_ms",
        "image_package_ms",
        "image_rebuild_ms"
      ],
      "properties": {
        "gradle_clean_build_ms": { "$ref": "#/$defs/duration" },
        "gradle_incremental_rebuild_ms": { "$ref": "#/$defs/duration" },
        "image_package_ms": { "$ref": "#/$defs/duration" },
        "image_rebuild_ms": { "$ref": "#/$defs/duration" }
      }
    }
  }
}
