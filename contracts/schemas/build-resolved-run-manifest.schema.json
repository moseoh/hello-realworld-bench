{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/build-resolved-run-manifest.schema.json",
  "title": "Resolved build run manifest",
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}(?![\\s\\S])"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*[\\u0000-\\u001f\\u007f])(?!\\.{1,2}(?:/|(?![\\s\\S])))(?!.*[/]\\.{1,2}(?:/|(?![\\s\\S])))[^/]+(?:/[^/]+)*(?![\\s\\S])"
    },
    "contractRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "schema_version", "contract_version", "digest", "path"],
      "properties": {
        "kind": {
          "enum": [
            "implementation",
            "variant",
            "environment-profile",
            "measurement-protocol",
            "build-profile"
          ]
        },
        "id": { "type": "string", "minLength": 1 },
        "schema_version": { "const": "1.0" },
        "contract_version": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "path": { "$ref": "#/$defs/relativePath" }
      }
    },
    "implementationContractRef": {
      "allOf": [
        { "$ref": "#/$defs/contractRef" },
        { "properties": { "kind": { "const": "implementation" } } }
      ]
    },
    "variantContractRef": {
      "allOf": [
        { "$ref": "#/$defs/contractRef" },
        { "properties": { "kind": { "const": "variant" } } }
      ]
    },
    "environmentProfileContractRef": {
      "allOf": [
        { "$ref": "#/$defs/contractRef" },
        { "properties": { "kind": { "const": "environment-profile" } } }
      ]
    },
    "measurementProtocolContractRef": {
      "allOf": [
        { "$ref": "#/$defs/contractRef" },
        { "properties": { "kind": { "const": "measurement-protocol" } } }
      ]
    },
    "buildProfileContractRef": {
      "allOf": [
        { "$ref": "#/$defs/contractRef" },
        { "properties": { "kind": { "const": "build-profile" } } }
      ]
    },
    "relativeBuildPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*%)(?!.*[\\u0000-\\u001f\\u007f])(?!\\.{1,2}(?:/|(?![\\s\\S])))(?!.*[/]\\.{1,2}(?:/|(?![\\s\\S])))[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*(?![\\s\\S])"
    },
    "buildContextPath": {
      "oneOf": [
        { "const": "." },
        { "$ref": "#/$defs/relativeBuildPath" }
      ]
    },
    "buildInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clean_command",
        "incremental_command",
        "incremental_input",
        "application_artifact",
        "dockerfile",
        "context"
      ],
      "properties": {
        "clean_command": {
          "type": "array",
          "prefixItems": [
            { "const": "./gradlew" },
            { "const": "clean" },
            { "const": "build" },
            { "const": "--offline" },
            { "const": "--no-daemon" },
            { "const": "--no-build-cache" }
          ],
          "items": false,
          "minItems": 6,
          "maxItems": 6
        },
        "incremental_command": {
          "type": "array",
          "prefixItems": [
            { "const": "./gradlew" },
            { "const": "build" },
            { "const": "--offline" },
            { "const": "--no-daemon" },
            { "const": "--no-build-cache" }
          ],
          "items": false,
          "minItems": 5,
          "maxItems": 5
        },
        "incremental_input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "from", "to"],
          "properties": {
            "path": { "const": "src/main/java/org/hellorealworld/benchmark/BuildBenchmarkProbe.java" },
            "from": { "const": "public static final int VALUE = 0;" },
            "to": { "const": "public static final int VALUE = 1;" }
          }
        },
        "application_artifact": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path"],
              "properties": {
                "type": { "const": "glob" },
                "path": { "const": "build/libs/*.jar" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path"],
              "properties": {
                "type": { "const": "directory" },
                "path": { "const": "build/quarkus-app" }
              }
            }
          ]
        },
        "dockerfile": { "$ref": "#/$defs/relativeBuildPath" },
        "context": { "$ref": "#/$defs/buildContextPath" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["git_commit", "git_dirty", "worktree_digest"],
      "properties": {
        "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}(?![\\s\\S])" },
        "git_dirty": { "type": "boolean" },
        "worktree_digest": { "$ref": "#/$defs/digest" }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "source",
    "selection",
    "contracts",
    "execution",
    "cohort",
    "manifest_digest"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "source": { "$ref": "#/$defs/source" },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation",
        "variant",
        "environment_profile",
        "measurement_protocol",
        "build_profile"
      ],
      "properties": {
        "implementation": { "type": "string", "minLength": 1 },
        "variant": { "type": "string", "minLength": 1 },
        "environment_profile": { "type": "string", "minLength": 1 },
        "measurement_protocol": { "type": "string", "minLength": 1 },
        "build_profile": { "type": "string", "minLength": 1 }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation",
        "variant",
        "environment_profile",
        "measurement_protocol",
        "build_profile"
      ],
      "properties": {
        "implementation": { "$ref": "#/$defs/implementationContractRef" },
        "variant": { "$ref": "#/$defs/variantContractRef" },
        "environment_profile": { "$ref": "#/$defs/environmentProfileContractRef" },
        "measurement_protocol": { "$ref": "#/$defs/measurementProtocolContractRef" },
        "build_profile": { "$ref": "#/$defs/buildProfileContractRef" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_dir", "variant_file", "build"],
      "properties": {
        "app_dir": { "$ref": "#/$defs/relativePath" },
        "variant_file": { "$ref": "#/$defs/relativePath" },
        "build": { "$ref": "#/$defs/buildInputs" }
      }
    },
    "cohort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_family", "contracts", "fingerprint"],
      "properties": {
        "evidence_family": { "const": "build" },
        "contracts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "environment_profile",
            "measurement_protocol",
            "build_profile"
          ],
          "properties": {
            "environment_profile": { "$ref": "#/$defs/environmentProfileContractRef" },
            "measurement_protocol": { "$ref": "#/$defs/measurementProtocolContractRef" },
            "build_profile": { "$ref": "#/$defs/buildProfileContractRef" }
          }
        },
        "fingerprint": { "$ref": "#/$defs/digest" }
      }
    },
    "manifest_digest": { "$ref": "#/$defs/digest" }
  }
}
