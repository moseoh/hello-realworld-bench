{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/measurement-protocol.schema.json",
  "title": "Benchmark measurement protocol contract",
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "status",
    "evidence_family",
    "trials",
    "timing_source",
    "warmup_seconds",
    "measured_seconds"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/slug" },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["development", "draft", "frozen"]
    },
    "evidence_family": { "type": "string", "minLength": 1 },
    "trials": { "type": "integer", "minimum": 1 },
    "timing_source": {
      "type": "string",
      "enum": ["scenario", "profile", "none"]
    },
    "warmup_seconds": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "measured_seconds": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_boundary", "completion_boundary"],
      "properties": {
        "start_boundary": { "const": "operation-command-start" },
        "completion_boundary": { "const": "operation-command-exit" }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_boundary",
        "completion_boundary",
        "observer_transport",
        "poll_interval_ms",
        "request_timeout_ms",
        "trial_timeout_seconds",
        "between_trials_seconds",
        "image_pull_policy"
      ],
      "properties": {
        "start_boundary": { "const": "image-entrypoint-pre-exec" },
        "completion_boundary": { "const": "first-valid-response-complete" },
        "observer_transport": { "const": "pod-localhost" },
        "poll_interval_ms": { "type": "integer", "minimum": 1 },
        "request_timeout_ms": { "type": "integer", "minimum": 1 },
        "trial_timeout_seconds": { "type": "integer", "minimum": 1 },
        "between_trials_seconds": { "type": "integer", "minimum": 0 },
        "image_pull_policy": { "const": "Never" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "evidence_family": { "const": "build" } },
        "required": ["evidence_family"]
      },
      "then": {
        "required": ["build"],
        "not": { "required": ["lifecycle"] },
        "properties": {
          "trials": { "const": 3 },
          "timing_source": { "const": "none" },
          "warmup_seconds": { "const": 0 },
          "measured_seconds": { "const": 0 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "frozen" },
          "evidence_family": { "const": "lifecycle" }
        },
        "required": ["status", "evidence_family"]
      },
      "then": { "required": ["lifecycle"] }
    }
  ]
}
