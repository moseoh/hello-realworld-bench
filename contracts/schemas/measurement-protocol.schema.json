{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/measurement-protocol.schema.json",
  "title": "Benchmark measurement protocol contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "status",
    "evidence_family",
    "trials",
    "timing_source",
    "warmup_seconds",
    "measured_seconds"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["development", "draft", "frozen"]
    },
    "evidence_family": { "type": "string", "minLength": 1 },
    "trials": { "type": "integer", "minimum": 1 },
    "timing_source": {
      "type": "string",
      "enum": ["scenario", "profile", "none"]
    },
    "warmup_seconds": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "measured_seconds": {
      "type": ["integer", "null"],
      "minimum": 0
    }
  }
}
