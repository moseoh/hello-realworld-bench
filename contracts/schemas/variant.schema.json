{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/variant.schema.json",
  "title": "Benchmark variant contract",
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    },
    "implementationId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    },
    "environmentName": {
      "description": "Project portability policy using POSIX-style environment variable names; intentionally stricter than Kubernetes 1.36.",
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?![\\s\\S])",
      "not": { "const": "JAVA_TOOL_OPTIONS" }
    },
    "environmentVariables": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/environmentName" },
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "implementation",
    "runtime",
    "docker"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/slug" },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "implementation": { "$ref": "#/$defs/implementationId" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build_mode"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "java_version": { "type": "string", "minLength": 1 },
        "framework_version": { "type": "string", "minLength": 1 },
        "spring_boot_version": { "type": "string", "minLength": 1 },
        "build_mode": { "type": "string", "minLength": 1 },
        "native_image": { "type": "boolean" },
        "virtual_threads": { "type": "boolean" },
        "otel": { "type": "boolean" }
      }
    },
    "docker": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "required": ["image_tag"],
      "properties": {
        "image": { "type": "string", "minLength": 1 },
        "image_tag": { "type": "string", "minLength": 1 },
        "build_context": { "type": "string", "minLength": 1 }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clean_command",
        "incremental_command",
        "incremental_input",
        "application_artifact",
        "dockerfile",
        "context"
      ],
      "properties": {
        "clean_command": {
          "type": "array",
          "prefixItems": [
            { "const": "./gradlew" },
            { "const": "clean" },
            { "const": "build" },
            { "const": "--offline" },
            { "const": "--no-daemon" },
            { "const": "--no-build-cache" }
          ],
          "items": false,
          "minItems": 6,
          "maxItems": 6
        },
        "incremental_command": {
          "type": "array",
          "prefixItems": [
            { "const": "./gradlew" },
            { "const": "build" },
            { "const": "--offline" },
            { "const": "--no-daemon" },
            { "const": "--no-build-cache" }
          ],
          "items": false,
          "minItems": 5,
          "maxItems": 5
        },
        "incremental_input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "from", "to"],
          "properties": {
            "path": { "const": "src/main/java/org/hellorealworld/benchmark/BuildBenchmarkProbe.java" },
            "from": { "const": "public static final int VALUE = 0;" },
            "to": { "const": "public static final int VALUE = 1;" }
          }
        },
        "application_artifact": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path"],
              "properties": {
                "type": { "const": "glob" },
                "path": { "const": "build/libs/*.jar" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "path"],
              "properties": {
                "type": { "const": "directory" },
                "path": { "const": "build/quarkus-app" }
              }
            }
          ]
        },
        "dockerfile": { "type": "string", "minLength": 1 },
        "context": { "type": "string", "minLength": 1 }
      }
    },
    "kubernetes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_environment"],
      "properties": {
        "target_environment": { "$ref": "#/$defs/environmentVariables" }
      }
    }
  }
}
