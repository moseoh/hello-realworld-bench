{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/implementation.schema.json",
  "title": "Benchmark implementation contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "language",
    "framework",
    "programming_model",
    "default_variant"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 1 },
    "framework": { "type": "string", "minLength": 1 },
    "programming_model": { "type": "string", "minLength": 1 },
    "default_variant": { "type": "string", "minLength": 1 }
  }
}
