{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/implementation.schema.json",
  "title": "Benchmark implementation contract",
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    },
    "implementationId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    },
    "environmentName": {
      "description": "Project portability policy using POSIX-style environment variable names; intentionally stricter than Kubernetes 1.36.",
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?![\\s\\S])",
      "not": { "const": "JAVA_TOOL_OPTIONS" }
    },
    "environmentVariables": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/environmentName" },
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "language",
    "framework",
    "programming_model",
    "default_variant",
    "default_build_profile",
    "official_image_repository",
    "kubernetes"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/implementationId" },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "language": { "$ref": "#/$defs/slug" },
    "framework": { "$ref": "#/$defs/slug" },
    "programming_model": { "type": "string", "minLength": 1 },
    "default_variant": { "$ref": "#/$defs/slug" },
    "default_build_profile": { "$ref": "#/$defs/slug" },
    "official_image_repository": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+(?::[0-9]+)?/[a-z0-9._-]+(?:/[a-z0-9._-]+)*(?![\\s\\S])"
    },
    "kubernetes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_environment"],
      "properties": {
        "target_environment": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/slug" },
          "additionalProperties": { "$ref": "#/$defs/environmentVariables" }
        }
      }
    }
  }
}
