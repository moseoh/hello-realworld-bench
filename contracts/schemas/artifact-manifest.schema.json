{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/artifact-manifest.schema.json",
  "title": "Benchmark raw artifact manifest",
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}(?![\\s\\S])"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*[\\u0000-\\u001f\\u007f])(?!\\.{1,2}(?:/|(?![\\s\\S])))(?!.*[/]\\.{1,2}(?:/|(?![\\s\\S])))[^/]+(?:/[^/]+)*(?![\\s\\S])"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trial_id", "artifacts"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "trial_id": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size_bytes", "sha256"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "$ref": "#/$defs/digest" },
          "media_type": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
