{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hellorealworld.dev/contracts/schemas/environment-profile.schema.json",
  "title": "Benchmark environment profile contract",
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?![\\s\\S])"
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu", "memory"],
      "properties": {
        "cpu": {
          "type": "string",
          "pattern": "^(?:[1-9][0-9]*|[1-9][0-9]*m)$"
        },
        "memory": {
          "type": "string",
          "pattern": "^[1-9][0-9]*(?:Ki|Mi|Gi|Ti)$"
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "contract_version",
    "description",
    "status",
    "orchestrator",
    "official",
    "load_generator"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "$ref": "#/$defs/slug" },
    "contract_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["development", "draft", "frozen"]
    },
    "orchestrator": { "type": "string", "minLength": 1 },
    "official": { "type": "boolean" },
    "load_generator": { "type": "string", "minLength": 1 },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner_labels",
        "platform",
        "machine_id",
        "cpu_model",
        "min_logical_cpus",
        "min_memory_bytes"
      ],
      "properties": {
        "runner_labels": {
          "type": "array",
          "prefixItems": [
            { "const": "self-hosted" },
            { "const": "linux" },
            { "const": "x64" },
            { "const": "hrw-home-k3s" }
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        },
        "platform": { "const": "linux/amd64" },
        "machine_id": { "const": "f66cd2d134b94bb18eb7e531d1baf343" },
        "cpu_model": { "const": "AMD Ryzen 7 5825U" },
        "min_logical_cpus": { "const": 16 },
        "min_memory_bytes": { "const": 29313151795 }
      }
    },
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context",
        "node_name",
        "machine_id",
        "architecture",
        "cpu_model",
        "cpu_manager_policy",
        "min_logical_cpus",
        "min_memory_bytes"
      ],
      "properties": {
        "context": { "type": "string", "minLength": 1 },
        "node_name": { "type": "string", "minLength": 1 },
        "machine_id": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
        "architecture": { "const": "amd64" },
        "cpu_model": { "type": "string", "minLength": 1 },
        "cpu_manager_policy": { "const": "none" },
        "min_logical_cpus": { "type": "integer", "minimum": 1 },
        "min_memory_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requests_equal_limits",
        "target",
        "dependency",
        "load_generator"
      ],
      "properties": {
        "requests_equal_limits": { "const": true },
        "target": { "$ref": "#/$defs/resources" },
        "dependency": { "$ref": "#/$defs/resources" },
        "load_generator": { "$ref": "#/$defs/resources" }
      }
    },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_platform",
        "target_digest_required",
        "k6"
      ],
      "properties": {
        "target_platform": { "const": "linux/amd64" },
        "target_digest_required": { "const": true },
        "k6": {
          "type": "string",
          "pattern": "^grafana/k6@sha256:[a-f0-9]{64}$"
        }
      }
    },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_background_cpu_millicores",
        "max_background_memory_bytes",
        "phases",
        "threshold_exceeded_classification"
      ],
      "properties": {
        "max_background_cpu_millicores": { "type": "integer", "minimum": 0 },
        "max_background_memory_bytes": { "type": "integer", "minimum": 0 },
        "max_load_generator_cpu_percent": { "type": "number", "exclusiveMinimum": 0 },
        "max_dependency_cpu_percent": { "type": "number", "exclusiveMinimum": 0 },
        "min_sample_coverage_ratio": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "stats_sample_interval_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "boundary_snapshot_count": { "const": 2 },
        "phases": {
          "type": "array",
          "items": {
            "enum": ["preflight", "in-run", "trial-boundary", "postflight"]
          },
          "uniqueItems": true
        },
        "threshold_exceeded_classification": {
          "const": "infrastructure-invalid"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["build"]
      },
      "then": {
        "properties": {
          "orchestrator": { "const": "host-build" },
          "official": { "const": true },
          "load_generator": { "const": "none" }
        },
        "not": {
          "anyOf": [
            { "required": ["cluster"] },
            { "required": ["resources"] },
            { "required": ["images"] },
            { "required": ["validity"] }
          ]
        }
      },
      "else": {
        "if": {
          "properties": { "official": { "const": true } },
          "required": ["official"]
        },
        "then": {
          "required": ["cluster", "resources", "images", "validity"]
        }
      }
    },
    {
      "if": {
        "properties": {
          "load_generator": { "const": "in-cluster-k6-observer" }
        },
        "required": ["load_generator"]
      },
      "then": {
        "properties": {
          "validity": {
            "required": ["boundary_snapshot_count"],
            "properties": {
              "phases": {
                "prefixItems": [
                  { "const": "preflight" },
                  { "const": "trial-boundary" },
                  { "const": "postflight" }
                ],
                "items": false,
                "minItems": 3,
                "maxItems": 3
              }
            }
          }
        }
      },
      "else": {
        "properties": {
          "validity": {
            "required": [
              "max_load_generator_cpu_percent",
              "max_dependency_cpu_percent",
              "min_sample_coverage_ratio",
              "stats_sample_interval_seconds"
            ],
            "properties": {
              "phases": {
                "prefixItems": [
                  { "const": "preflight" },
                  { "const": "in-run" },
                  { "const": "postflight" }
                ],
                "items": false,
                "minItems": 3,
                "maxItems": 3
              }
            }
          }
        }
      }
    }
  ]
}
